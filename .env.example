# Email credentials are required only when sending real email.
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECIPIENTS=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Report schedule.
REPORT_FREQUENCY=daily
REPORT_TIME=09:00

# Data source.
DATA_SOURCE_TYPE=csv
DATA_SOURCE_PATH=data/sample_data.csv

# AI is disabled by default so local dry-runs do not require network access.
AI_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-r1-0528:free
OPENROUTER_MAX_TOKENS=150
AI_REQUEST_TIMEOUT=30
SITE_URL=http://localhost
SITE_NAME=Email Report App

# Optional local Hugging Face backend. Requires requirements-ai.txt and cached model files.
USE_LOCAL_MODEL=false
HF_MODEL=distilgpt2
HF_MAX_LENGTH=100

# Retry and logging.
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=60.0
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_DIR=logs
